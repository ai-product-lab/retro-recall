{
  "name": "retro-recall",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @retro-recall/bubble-buddies dev",
    "new-game": "node tools/scaffold/index.mjs",
    "typecheck": "tsc --build",
    "test": "vitest run && pnpm --filter @retro-recall/rooms-worker test && pnpm --filter @retro-recall/avatar-worker test",
    "test:watch": "vitest",
    "lint": "eslint .",
    "build:site": "node tools/build-site.mjs",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build:site",
    "loadtest": "node tools/loadtest/index.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^25.9.3",
    "eslint": "^9.30.0",
    "globals": "^16.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.40.0",
    "vitest": "^3.2.0"
  }
}

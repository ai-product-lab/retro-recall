/*
 * __NAME__ shell styles (ADR-007 mobile-first). Brand palette
 * (branding/BRAND.md). Canvas is integer-scaled by layout.ts; this file styles
 * the stage and touch controls and reflows them per orientation.
 */

:root {
  color-scheme: dark;
  --midnight: #0f1222;
  --raised: #1a1f38;
  --phosphor: #3df5a6;
  --paper: #f2efe9;
  --dim: #8a8fa3;
  --line: #2a3158;
}

* { box-sizing: border-box; }

html, body {
  margin: 0;
  height: 100%;
  background: var(--midnight);
  color: var(--paper);
  font-family: ui-monospace, Menlo, Consolas, monospace;
  overscroll-behavior: none;
}

body {
  touch-action: none;
  -webkit-user-select: none;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
}
body[data-input='keyboard'] .ctl-zone { display: none; }
body[data-input='touch'] .keys-only { display: none; }

#stage {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: calc(env(safe-area-inset-top) + 10px) 10px calc(env(safe-area-inset-bottom) + 10px);
}

#title { font-size: 14px; letter-spacing: 3px; color: var(--phosphor); margin: 4px 0 0; }

canvas#game {
  image-rendering: pixelated;
  background: #0d0d2b;
  outline: 2px solid var(--line);
  outline-offset: 2px;
}

.hint { font-size: 11px; color: var(--dim); }

/* --- Touch controls --- */

#controls {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: auto;
}

.ctl-zone { display: flex; gap: 14px; }

.ctl {
  width: 64px;
  height: 64px;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: var(--raised);
  color: var(--paper);
  font-size: 22px;
  font-family: inherit;
}
.ctl:active { background: var(--line); transform: scale(0.95); }
.ctl.jump {
  background: var(--phosphor);
  border-color: var(--phosphor);
  color: #06281a;
}

/* Portrait: controls hug the bottom corners with room between. */
body[data-orientation='landscape'] #controls { padding: 0 6px; }
